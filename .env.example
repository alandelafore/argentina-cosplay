# JWT
JWT_SECRET=supersecretkey
JWT_REFRESH_SECRET=anothersecretkey
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Marketplace configuration
PLATFORM_COMMISSION_PERCENTAGE=10
