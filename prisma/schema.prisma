generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COMPRADOR
  VENDEDOR
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  PAGADO
  ENVIADO
  ENTREGADO
  CANCELADO
  REEMBOLSADO
}

enum ProductCondition {
  NUEVO
  USADO
}

enum DisputeStatus {
  ABIERTA
  EN_REVISION
  RESUELTA
  CERRADA
}

enum ShippingStatus {
  PENDIENTE
  EN_TRANSITO
  ENTREGADO
  DEVUELTO
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  name           String
  password       String
  phone          String?
  cuit           String?        @unique
  isSuspended    Boolean        @default(false)
  roles          UserRole[]
  favorites      Favorite[]     @relation("FavoriteUser")
  sellerFavorites Favorite[]    @relation("FavoriteSeller")
  products       Product[]      @relation("SellerProducts")
  carts          Cart[]
  orders         Order[]        @relation("BuyerOrders")
  reviews        Review[]
  disputes       Dispute[]      @relation("BuyerDisputes")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role

  @@id([userId, role])
  @@index([role])
}

model Category {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  parent      Category?   @relation("CategoryChildren", fields: [parentId], references: [id])
  parentId    String?
  children    Category[]  @relation("CategoryChildren")
  attributes  CategoryAttribute[]
  products    Product[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model CategoryAttribute {
  id                String             @id @default(uuid())
  category          Category           @relation(fields: [categoryId], references: [id])
  categoryId        String
  name              String
  type              String
  required          Boolean            @default(false)
  options           String[]           @default([])
  productAttributes ProductAttribute[]
  createdAt         DateTime           @default(now())
}

model Product {
  id              String             @id @default(uuid())
  seller          User               @relation("SellerProducts", fields: [sellerId], references: [id])
  sellerId        String
  category        Category           @relation(fields: [categoryId], references: [id])
  categoryId      String
  title           String
  description     String
  price           Float
  condition       ProductCondition
  status          String             @default("ACTIVE")
  stock           Int                @default(0)
  tags            String[]           @default([])
  metadata        Json?
  variants        ProductVariant[]
  attributes      ProductAttribute[]
  images          ProductImage[]
  reviews         Review[]
  orderItems      OrderItem[]
  favorites       Favorite[]
  cartItems       CartItem[]
  auditLogs       ProductAudit[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([categoryId])
  @@index([sellerId])
  @@index([status])
  @@index([price])
  @@index([createdAt])
}

model ProductVariant {
  id          String   @id @default(uuid())
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  sku         String   @unique
  size        String?
  color       String?
  stock       Int      @default(0)
  price       Float?
  metadata    Json?
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
}

model ProductAttribute {
  id                   String   @id @default(uuid())
  product              Product  @relation(fields: [productId], references: [id])
  productId            String
  attributeDefinition  CategoryAttribute @relation(fields: [attributeDefinitionId], references: [id])
  attributeDefinitionId String
  value                String
}

model ProductImage {
  id          String   @id @default(uuid())
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  url         String
  position    Int      @default(0)
}

model Favorite {
  id         String   @id @default(uuid())
  user       User     @relation("FavoriteUser", fields: [userId], references: [id])
  userId     String
  product    Product? @relation(fields: [productId], references: [id])
  productId  String?
  seller     User?    @relation("FavoriteSeller", fields: [sellerId], references: [id])
  sellerId   String?
  createdAt  DateTime @default(now())
}

model Cart {
  id          String      @id @default(uuid())
  user        User        @relation(fields: [userId], references: [id])
  userId      String      @unique
  sellerId    String
  items       CartItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model CartItem {
  id          String   @id @default(uuid())
  cart        Cart     @relation(fields: [cartId], references: [id])
  cartId      String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  variantId   String?
  quantity    Int      @default(1)
  unitPrice   Float
}

model Order {
  id            String           @id @default(uuid())
  buyer         User             @relation("BuyerOrders", fields: [buyerId], references: [id])
  buyerId       String
  sellerId      String
  status        OrderStatus      @default(PENDIENTE)
  totalAmount   Float
  commission    Float
  payment       Payment?
  shipping      Shipping?
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([sellerId])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  variantId   String?
  quantity    Int      @default(1)
  unitPrice   Float
}

model OrderStatusHistory {
  id          String      @id @default(uuid())
  order       Order       @relation(fields: [orderId], references: [id])
  orderId     String
  fromStatus  OrderStatus
  toStatus    OrderStatus
  note        String?
  createdAt   DateTime    @default(now())
}

model Payment {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String   @unique
  provider    String
  rawResponse Json
  amount      Float
  method      String
  refunded    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Shipping {
  id             String         @id @default(uuid())
  order          Order          @relation(fields: [orderId], references: [id])
  orderId        String         @unique
  carrier        String
  trackingNumber String?
  status         ShippingStatus @default(PENDIENTE)
  cost           Float
  rawResponse    Json?
  updates        ShippingUpdate[]
  createdAt      DateTime       @default(now())
}

model ShippingUpdate {
  id          String    @id @default(uuid())
  shipping    Shipping  @relation(fields: [shippingId], references: [id])
  shippingId  String
  status      ShippingStatus
  message     String?
  createdAt   DateTime  @default(now())
}

model Review {
  id          String   @id @default(uuid())
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  buyer       User     @relation(fields: [buyerId], references: [id])
  buyerId     String
  rating      Int
  comment     String?
  photos      String[] @default([])
  deliveredAt DateTime
  createdAt   DateTime @default(now())
}

model Dispute {
  id          String       @id @default(uuid())
  buyer       User         @relation("BuyerDisputes", fields: [buyerId], references: [id])
  buyerId     String
  sellerId    String
  orderId     String
  reason      String
  evidence    String[]     @default([])
  status      DisputeStatus @default(ABIERTA)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ProductAudit {
  id         String   @id @default(uuid())
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  changeType String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())
}
